#!/bin/bash

# Blog CLI 快捷启动脚本
# 使用方法：./blog [命令] 或添加到 PATH 后直接使用 blog

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CLI_SCRIPT="$SCRIPT_DIR/scripts/blog-cli.js"

# 检查 Node.js
if ! command -v node &> /dev/null; then
    echo "❌ 错误：未找到 Node.js"
    echo "请先安装 Node.js: https://nodejs.org/"
    exit 1
fi

# 执行 CLI
exec node "$CLI_SCRIPT" "$@"
