# =============================================================================
# Blog Platform Environment Variables Template
# =============================================================================
# 复制此文件为 .env.local (本地开发) 或在 Vercel 中配置 (生产环境)
# cp .env.example .env.local
# =============================================================================

# =============================================================================
# 数据库配置 (必填)
# =============================================================================
# PostgreSQL 连接字符串 (推荐用于 Vercel 部署)
# 示例: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/blog?sslmode=require"

# =============================================================================
# NextAuth 认证配置 (必填)
# =============================================================================
# 生成随机密钥: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
# 本地开发使用 http://localhost:3000，生产环境使用 https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# 网站配置 (必填)
# =============================================================================
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="My Blog"

# =============================================================================
# AI 配置 (可选)
# =============================================================================
# OpenAI API 配置
OPENAI_API_KEY="sk-xxx"
OPENAI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-3.5-turbo"

# =============================================================================
# 文件存储配置
# =============================================================================
# 存储驱动: local (本地), s3 (AWS S3), oss (阿里云 OSS)
STORAGE_DRIVER=local

# 本地存储路径
STORAGE_LOCAL_PATH=./uploads
STORAGE_LOCAL_URL=/uploads
STORAGE_LOCAL_SERVE_STATIC=true

# =============================================================================
# 上传配置
# =============================================================================
# 最大文件大小 (字节): 100MB
UPLOAD_MAX_FILE_SIZE=104857600
# 按日期组织文件
UPLOAD_ORGANIZE_BY_DATE=true
# 生成唯一文件名
UPLOAD_UNIQUE_FILENAME=true

# =============================================================================
# CDN 配置 (可选)
# =============================================================================
NEXT_PUBLIC_CDN_ENABLED=false
NEXT_PUBLIC_CDN_PROVIDER=custom
NEXT_PUBLIC_CDN_BASE_URL=https://cdn.example.com

# =============================================================================
# 支付配置 (可选)
# =============================================================================
# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# 支付宝
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=alipay-public-key

# 微信支付
WECHAT_PAY_APP_ID=your-wechat-app-id
WECHAT_PAY_MCH_ID=your-merchant-id
WECHAT_PAY_API_KEY=your-api-key
