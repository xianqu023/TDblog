# ============================================
# 博客平台环境变量配置
# ============================================
# 说明：复制此文件为 .env 并修改相应配置
# ============================================

# --------------------------------------------
# 应用配置
# --------------------------------------------
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production

# 应用端口
PORT=3000

# 应用 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --------------------------------------------
# 数据库配置
# --------------------------------------------
# SQLite 数据库路径（相对路径或绝对路径）
DATABASE_URL="file:./packages/database/prisma/blog.db"

# 生产环境建议使用 MySQL 或 PostgreSQL
# DATABASE_URL="mysql://user:password@localhost:3306/blog"
# DATABASE_URL="postgresql://user:password@localhost:5432/blog"

# --------------------------------------------
# 认证配置
# --------------------------------------------
# JWT 密钥（生产环境请使用强随机字符串）
# 生成方法：openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT 过期时间
JWT_EXPIRES_IN=7d

# 会话密钥
NEXTAUTH_SECRET=your-nextauth-secret-key-change-this

# NextAuth URL
NEXTAUTH_URL=http://localhost:3000

# --------------------------------------------
# 文件上传配置
# --------------------------------------------
# 上传目录
UPLOAD_DIR=./uploads

# 最大上传大小（字节）
MAX_UPLOAD_SIZE=10485760

# 允许的上传类型
ALLOWED_UPLOAD_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# --------------------------------------------
# 邮件配置（可选）
# --------------------------------------------
# SMTP 服务器
SMTP_HOST=smtp.example.com

# SMTP 端口
SMTP_PORT=587

# SMTP 用户
SMTP_USER=your-smtp-user

# SMTP 密码
SMTP_PASS=your-smtp-password

# 发件人邮箱
SMTP_FROM=noreply@example.com

# --------------------------------------------
# 第三方服务（可选）
# --------------------------------------------
# Google Analytics
NEXT_PUBLIC_GA_ID=

# Google AdSense
NEXT_PUBLIC_ADSENSE_ID=

# Cloudflare Turnstile (验证码)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --------------------------------------------
# 日志配置
# --------------------------------------------
# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# 日志目录
LOG_DIR=./logs

# --------------------------------------------
# 缓存配置
# --------------------------------------------
# Redis URL（可选，用于缓存）
# REDIS_URL=redis://localhost:6379

# --------------------------------------------
# 构建配置
# --------------------------------------------
# 禁用 Source Map（生产环境）
GENERATE_SOURCEMAP=false

# 禁用 TypeScript 检查
# NEXT_TYPESCRIPT_IGNORE=false

# 禁用 ESLint 检查
# NEXT_LINT_IGNORE=false

# --------------------------------------------
# 国际化配置
# --------------------------------------------
# 默认语言
NEXT_PUBLIC_DEFAULT_LOCALE=zh

# 支持的语言列表
NEXT_PUBLIC_LOCALES=zh,en

# --------------------------------------------
# 性能优化
# --------------------------------------------
# 启用图片优化
NEXT_PUBLIC_IMAGE_OPTIMIZATION=true

# 启用字体优化
NEXT_PUBLIC_FONT_OPTIMIZATION=true

# --------------------------------------------
# 安全配置
# --------------------------------------------
# 内容安全策略
# CSP_REPORT_URI=

# HSTS 最大年龄
# HSTS_MAX_AGE=31536000

# --------------------------------------------
# 开发环境专用
# --------------------------------------------
# 开发数据库
# DATABASE_URL_DEV="file:./packages/database/prisma/blog-dev.db"

# 测试数据库
# DATABASE_URL_TEST="file:./packages/database/prisma/blog-test.db"
