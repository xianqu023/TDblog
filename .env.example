# Database Configuration
# Database provider: mysql, postgresql, or sqlite
DB_PROVIDER=mysql

# MySQL Configuration
MYSQL_ROOT_PASSWORD=your-secure-root-password
MYSQL_DATABASE=blog
MYSQL_USER=bloguser
MYSQL_PASSWORD=your-secure-db-password
DATABASE_URL="mysql://bloguser:your-secure-db-password@localhost:3306/blog"

# PostgreSQL Configuration (uncomment if using PostgreSQL)
# POSTGRES_PASSWORD=your-secure-db-password
# DATABASE_URL="postgresql://bloguser:your-secure-db-password@localhost:5432/blog"

# SQLite Configuration (uncomment if using SQLite)
# DATABASE_URL="file:./blog.db"

# NextAuth Configuration
NEXTAUTH_SECRET=generate-a-random-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=My Blog

# Stripe (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# PayPal (optional)
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# Alipay (optional)
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=alipay-public-key

# WeChat Pay (optional)
WECHAT_PAY_APP_ID=your-wechat-app-id
WECHAT_PAY_MCH_ID=your-merchant-id
WECHAT_PAY_API_KEY=your-api-key

# =============================================================================
# File Storage Configuration
# =============================================================================

# Storage Driver: local, s3, or oss
# - local: Store files on local filesystem
# - s3: AWS S3 or S3-compatible services (MinIO, etc.)
# - oss: Alibaba Cloud OSS
STORAGE_DRIVER=local

# -----------------------------------------------------------------------------
# Local Storage Configuration
# -----------------------------------------------------------------------------
# Base path for storing files (relative to project root or absolute path)
STORAGE_LOCAL_PATH=./uploads
# URL path for accessing files (if serveStatic is true)
STORAGE_LOCAL_URL=/uploads
# Whether to serve files statically (true/false)
STORAGE_LOCAL_SERVE_STATIC=true

# -----------------------------------------------------------------------------
# AWS S3 Configuration
# -----------------------------------------------------------------------------
# AWS Region (e.g., us-east-1, ap-northeast-1)
STORAGE_S3_REGION=us-east-1
# S3 Bucket name
STORAGE_S3_BUCKET=your-bucket-name
# AWS Access Key ID
STORAGE_S3_ACCESS_KEY_ID=your-access-key-id
# AWS Secret Access Key
STORAGE_S3_SECRET_ACCESS_KEY=your-secret-access-key
# Custom endpoint for S3-compatible services (e.g., MinIO)
# Leave empty for standard AWS S3
# Example for MinIO: http://localhost:9000
STORAGE_S3_ENDPOINT=
# Force path-style URLs (required for MinIO)
# Set to 'true' for MinIO, 'false' for AWS S3
STORAGE_S3_FORCE_PATH_STYLE=false
# Public URL for accessing files (e.g., CloudFront CDN URL)
# If not set, will use standard S3 URL
STORAGE_S3_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Alibaba Cloud OSS Configuration
# -----------------------------------------------------------------------------
# OSS Region (e.g., oss-cn-hangzhou, oss-cn-beijing)
STORAGE_OSS_REGION=oss-cn-hangzhou
# OSS Bucket name
STORAGE_OSS_BUCKET=your-bucket-name
# Alibaba Cloud Access Key ID
STORAGE_OSS_ACCESS_KEY_ID=your-access-key-id
# Alibaba Cloud Access Key Secret
STORAGE_OSS_ACCESS_KEY_SECRET=your-access-key-secret
# Custom endpoint (optional, for VPC internal network or custom domain)
# Example: oss-cn-hangzhou-internal.aliyuncs.com
STORAGE_OSS_ENDPOINT=
# Use internal endpoint (for ECS within same region)
# Set to 'true' to reduce traffic costs
STORAGE_OSS_INTERNAL=false
# Public URL for accessing files (e.g., CDN accelerated domain)
# If not set, will use standard OSS URL
STORAGE_OSS_PUBLIC_URL=

# =============================================================================
# Upload Configuration
# =============================================================================

# Maximum file size in bytes (default: 100MB)
UPLOAD_MAX_FILE_SIZE=104857600

# Allowed MIME types (comma-separated, leave empty to allow all)
# Example: image/jpeg,image/png,application/pdf
UPLOAD_ALLOWED_MIME_TYPES=

# Upload path prefix (default: uploads)
UPLOAD_PATH_PREFIX=uploads

# Organize files by date (true/false)
# If true, files will be stored in uploads/YYYY/MM/DD/ format
UPLOAD_ORGANIZE_BY_DATE=true

# Generate unique filename (true/false)
# If true, filenames will be timestamp-random.ext format
UPLOAD_UNIQUE_FILENAME=true

# =============================================================================
# CDN Configuration
# =============================================================================

# Enable CDN (true/false)
NEXT_PUBLIC_CDN_ENABLED=false

# CDN Provider: custom, aliyun, qcloud, cloudflare, aws, baidu
NEXT_PUBLIC_CDN_PROVIDER=custom

# CDN Base URL for static assets
NEXT_PUBLIC_CDN_BASE_URL=https://cdn.example.com

# CDN URL for images (optional, defaults to base URL)
NEXT_PUBLIC_CDN_IMAGE_URL=https://img.example.com

# CDN URL for CSS files (optional, defaults to base URL)
NEXT_PUBLIC_CDN_CSS_URL=https://css.example.com

# CDN URL for JS files (optional, defaults to base URL)
NEXT_PUBLIC_CDN_JS_URL=https://js.example.com

# Enable DNS preconnect (true/false)
NEXT_PUBLIC_CDN_PRECONNECT=true

# Enable image optimization (true/false)
NEXT_PUBLIC_CDN_IMAGE_OPTIMIZATION=false

# Enable WebP auto conversion (true/false)
NEXT_PUBLIC_CDN_WEBP_ENABLED=false
