[database]
# 数据库类型: mysql, postgresql, sqlite
provider = postgresql

# 数据库连接字符串
url = postgresql://user:password@localhost:5432/blog

[server]
# 服务端口
port = 3000

# 服务主机
host = 0.0.0.0

# Node 环境
node_env = production

[auth]
# NextAuth 密钥（生产环境请修改为随机字符串）
secret = your-secret-key-change-in-production

# 认证 URL
url = http://localhost:3000

[site]
# 网站名称
name = My Blog

# 网站 URL
url = http://localhost:3000

[storage]
# 存储驱动: local, s3, oss
driver = local

# 本地存储路径
local_path = ./uploads

# 本地存储 URL 前缀
local_url = /uploads
